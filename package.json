{
  "name": "conference-breakout",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time live-event engagement platform (Next.js + Deno)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently -n host,client,realtime -c blue,magenta,cyan \"pnpm --filter @app/host dev\" \"pnpm --filter @app/client dev\" \"pnpm dev:realtime\"",
    "dev:realtime": "cd apps/realtime && deno task dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "load-test": "cd apps/realtime && deno task load-test"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
